{{!
    @template report_studentgrades/index

    Student grades report index page template.

    Context variables required for this template:
    * showuserselection - boolean
    * userid - int
    * fullname - string
    * enableemailanalysis - boolean
    * enableinstantanalysis - boolean
    * users - array of objects (id, fullname, selected)

    Example context (json):
    {
        "showuserselection": true,
        "userid": 2,
        "fullname": "John Doe",
        "enableemailanalysis": true,
        "enableinstantanalysis": true,
        "users": [
            { "id": 2, "fullname": "John Doe", "selected": true },
            { "id": 3, "fullname": "Jane Doe", "selected": false }
        ]
    }
}}
{{#showuserselection}}
    <h2>{{#str}} selectuser, report_studentgrades {{/str}}</h2>
    <form method="get" action="">
        <div class="form-group">
            <label for="userid">{{#str}} selectuser, report_studentgrades {{/str}}</label>
            <select id="userid" name="userid" class="form-control">
                <option value="">{{#str}} choosedots {{/str}}</option>
                {{#users}}
                    <option value="{{id}}" {{#selected}}selected{{/selected}}>{{fullname}}</option>
                {{/users}}
            </select>
        </div>
        <button type="submit" class="btn btn-primary">{{#str}} view {{/str}}</button>
    </form>
    <hr>
{{/showuserselection}}

<h2>{{fullname}}</h2>

<form method="post" action="" style="display: inline-block; margin-right: 10px;">
    <input type="hidden" name="userid" value="{{userid}}">
    <input type="hidden" name="action" value="export">
    <button type="submit" class="btn btn-primary btn-lg">{{#str}} exporthtml, report_studentgrades {{/str}}</button>
</form>

{{#enableemailanalysis}}
    <form method="post" action="" style="display: inline-block;">
        <input type="hidden" name="userid" value="{{userid}}">
        <input type="hidden" name="action" value="analyze">
        <button type="submit" class="btn btn-info btn-lg">{{#str}} analyzeandemail, report_studentgrades {{/str}}</button>
    </form>
{{/enableemailanalysis}}

{{#enableinstantanalysis}}
    <button id="btn-moodle-ai-test" class="btn btn-success btn-lg" style="margin-left: 10px;" data-userid="{{userid}}">
        {{#str}} viewanalysisnow, report_studentgrades {{/str}}
    </button>
{{/enableinstantanalysis}}
